financial_year: 2025  # ending June 30

taxpayer:
  name: "Your Name"
  # spouse:
  #   name: "Spouse Name"
  #   taxable_income: 0

businesses:
  - name: "My Business"
    abn: "00000000000"
    activity: "Your business activity"
    split_rules:
      # Personal categories that are partially business use
      - category: Utilities
        tag: internet
        business_pct: 50      # % of internet bill that's business use
      - category: Utilities
        tag: mobile
        business_pct: 20
    # Categories starting with "Business:" are implicitly 100% allocated

